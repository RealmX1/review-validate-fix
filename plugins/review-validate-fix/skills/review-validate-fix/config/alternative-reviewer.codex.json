{
  "enabled": true,
  "label": "alternative-reviewer:codex-cli",
  "command": [
    "codex",
    "--ask-for-approval",
    "never",
    "exec",
    "--json",
    "--ephemeral",
    "--sandbox",
    "workspace-write",
    "-"
  ],
  "allow_repo_cwd": true,
  "idle_timeout_seconds": 300,
  "activity_check_interval_seconds": 5,
  "activity_probe_command": null,
  "activity_probe_timeout_seconds": 10,
  "activity_probe_failure_threshold": 3,
  "max_runtime_seconds": null,
  "health_timeout_seconds": 30,
  "pre_run_health": true,
  "output_format": "codex_json",
  "env_unset": [
    "ANTHROPIC_API_KEY"
  ],
  "health_command": [
    "codex",
    "login",
    "status"
  ]
}
