{
  "enabled": true,
  "label": "alternative-reviewer:claude-code",
  "command": [
    "claude",
    "-p",
    "--output-format",
    "stream-json",
    "--include-hook-events",
    "--include-partial-messages",
    "--no-session-persistence",
    "--tools",
    "Bash,Read"
  ],
  "allow_repo_cwd": true,
  "idle_timeout_seconds": 300,
  "activity_check_interval_seconds": 5,
  "activity_probe_command": null,
  "activity_probe_timeout_seconds": 10,
  "activity_probe_failure_threshold": 3,
  "max_runtime_seconds": null,
  "health_timeout_seconds": 30,
  "output_format": "claude_stream_json",
  "env_unset": [
    "ANTHROPIC_API_KEY"
  ],
  "health_command": [
    "claude",
    "auth",
    "status"
  ]
}
